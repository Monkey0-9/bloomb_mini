# SatTrade Institutional Terminal - Configuration
# Documentation: 15 Core Configuration Keys

# --- AUTHENTICATION ---
# RS256 Private/Public Key (Base64 encoded)
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=
JWT_ALGORITHM=RS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30

# --- CORE SERVICES ---
REDIS_URL=redis://localhost:6379/0
DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/sattrade
FRONTEND_URL=http://localhost:3000

# --- EXTERNAL APIS ---
# Anthropic Claude 3.5 Sonnet
CLAUDE_API_KEY=
# Alpha-Vantage (Market Data)
ALPHA_VANTAGE_API_KEY=
# Spire/AIS (Maritime Data)
SPIRE_API_KEY=
# OpenSky (Aviation Data)
OPENSKY_USERNAME=
OPENSKY_PASSWORD=
# Kpler (Global Cargo/Commodity)
KPLER_API_KEY=

# --- MODEL INFERENCE ---
# Path to TFT model weights
TFT_MODEL_PATH=./models/tft_v0.1.pt
DEVICE=cuda

# --- LOGGING ---
LOG_LEVEL=INFO
APP_NAME=sattrade-terminal
