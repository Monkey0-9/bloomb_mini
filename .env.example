# Copernicus Data Space (free — register at dataspace.copernicus.eu)
COPERNICUS_CLIENT_ID=your_client_id_here
COPERNICUS_CLIENT_SECRET=your_client_secret_here

# Alpaca Markets (free paper trading — alpaca.markets)
ALPACA_API_KEY=your_alpaca_key_here
ALPACA_SECRET_KEY=your_alpaca_secret_here
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# Database paths (defaults work for local development)
CATALOG_DB_PATH=data/catalog.db
FEATURES_DB_PATH=data/features.db
HOLDOUT_DB_PATH=data/holdout.db

# Model storage
MLFLOW_TRACKING_URI=http://localhost:5000

# Monitoring
PROMETHEUS_PORT=9090
